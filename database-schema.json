      "definition": " SELECT min(ownedcardid) AS ownedcardid,\n    userid,\n    cardid,\n    min(packid) AS packid,\n    count(*)::integer AS quantity\n   FROM pbe_collection\n  GROUP BY userid, cardid;"
    },
    "pbe_pack_today": {
      "description": "Auto-updating count of packs purchased today (base, ruby/ultimus, throwback, event) - resets daily at midnight EST (America/New_York timezone). Assumes purchasedate is stored in UTC.",
      "definition": " SELECT userid,\n    count(*) FILTER (WHERE packtype::text = 'base'::text)::integer AS base,\n    count(*) FILTER (WHERE packtype::text = 'ruby'::text)::integer AS ruby,\n    count(*) FILTER (WHERE packtype::text = 'throwback'::text)::integer AS throwback,\n    count(*) FILTER (WHERE packtype::text = 'event'::text)::integer AS event,\n    (CURRENT_TIMESTAMP AT TIME ZONE 'America/New_York'::text)::date AS date\n   FROM pbe_packs_owned\n  WHERE date(((purchasedate AT TIME ZONE 'UTC'::text) AT TIME ZONE 'America/New_York'::text)) = (CURRENT_TIMESTAMP AT TIME ZONE 'America/New_York'::text)::date\n  GROUP BY userid;"
    },
    "trade_details": {
      "description": "Denormalized view of trade data joining trades, trade assets, collection, and card details",
      "definition": " SELECT t.tradeid,\n    t.initiatorid,\n    t.recipientid,\n    t.trade_status,\n    ta.ownedcardid,\n    c.cardid,\n    card.image_url,\n    ta.toid,\n    ta.fromid,\n    t.create_date,\n    t.update_date,\n    card.card_rarity,\n    card.sub_type\n   FROM pbe_trades t\n     JOIN pbe_trade_assets ta ON t.tradeid = ta.tradeid\n     JOIN pbe_collection c ON ta.ownedcardid = c.ownedcardid\n     JOIN pbe_cards card ON c.cardid = card.cardid;"
    },
    "unique_cards": {
      "description": null,
      "definition": " SELECT card_rarity,\n    count(DISTINCT cardid)::integer AS total_count\n   FROM pbe_cards\n  WHERE approved = true AND card_rarity IS NOT NULL\n  GROUP BY card_rarity\n  ORDER BY (\n        CASE card_rarity\n            WHEN 'Common'::text THEN 1\n            WHEN 'Uncommon'::text THEN 2\n            WHEN 'Rare'::text THEN 3\n            WHEN 'Mythic'::text THEN 4\n            ELSE 5\n        END);"
    },
    "user_unique_cards": {
      "description": null,
      "definition": " WITH user_rarity_counts AS (\n         SELECT oc.userid,\n            cards.card_rarity,\n            count(DISTINCT oc.cardid)::integer AS owned_count\n           FROM pbe_owned_cards oc\n             JOIN pbe_cards cards ON oc.cardid = cards.cardid\n          WHERE cards.approved = true AND cards.card_rarity IS NOT NULL\n          GROUP BY oc.userid, cards.card_rarity\n        ), ranked_users AS (\n         SELECT user_rarity_counts.userid,\n            user_rarity_counts.card_rarity,\n            user_rarity_counts.owned_count,\n            dense_rank() OVER (PARTITION BY user_rarity_counts.card_rarity ORDER BY user_rarity_counts.owned_count DESC) AS rarity_rank\n           FROM user_rarity_counts\n        )\n SELECT userid,\n    card_rarity,\n    owned_count,\n    rarity_rank\n   FROM ranked_users r\n  ORDER BY (\n        CASE card_rarity\n            WHEN 'Common'::text THEN 1\n            WHEN 'Uncommon'::text THEN 2\n            WHEN 'Rare'::text THEN 3\n            WHEN 'Mythic'::text THEN 4\n            ELSE 5\n        END), rarity_rank;"
    }
  }
}