# ===========================================
# PBE Trading Cards - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# -----------------------------
# NODE ENVIRONMENT
# -----------------------------
NODE_ENV=development

# -----------------------------
# POSTGRESQL (Cards Database)
# -----------------------------
# PBE Trading Cards uses PostgreSQL for card-specific data
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DATABASE=pbe_cards

# -----------------------------
# PORTAL API
# -----------------------------
# Portal API URL - Points to PBE Portal instance (include https://)
# All user, team, player, and bank data comes from Portal APIs
PORTAL_API_URL=https://pbe.simflow.io
# PBE portal API — REST endpoints TBD
# API Token created in Portal for external API calls
PORTAL_API_KEY=your_api_token_here

# -----------------------------
# AUTHENTICATION
# -----------------------------
# JWT secret for session tokens
SECRET=your_jwt_secret_here_min_32_chars
# Public token key for client-side
NEXT_PUBLIC_TOKEN_KEY=your_public_token_key

# -----------------------------
# VERCEL BLOB STORAGE
# -----------------------------
# Token for uploading images to Vercel Blob
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# -----------------------------
# CRON JOB SECURITY
# -----------------------------
# Secret key for authenticating cron job requests
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your_cron_secret_here

# -----------------------------
# EXTERNAL API SECURITY
# -----------------------------
# Secret key for authenticating external API requests (e.g. grant-free-packs)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EXTERNAL_API_KEY=your_external_api_key_here

# -----------------------------
# CLOUDFLARE R2 (Image Storage)
# -----------------------------
# R2 credentials for direct image uploads
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=pbe-trading-cards
# Public URL for accessing uploaded images (e.g., https://pub-xxxxx.r2.dev or your custom domain)
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# -----------------------------
# GITHUB (Optional)
# -----------------------------
# For creating GitHub issues from the app
GITHUB_ISSUES_TOKEN=your_github_token_here
